// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELO: Usuário
// ==========================================
model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  cargo     String?
  role      UserRole @default(COLABORADOR)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  configuracao   Configuracao?
  registros      RegistroPonto[]
  justificativas Justificativa[]
  bancoHoras     BancoHoras?
  logs           Log[]

  @@map("users")
}

// ==========================================
// MODELO: Configurações do usuário
// ==========================================
model Configuracao {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  jornadaPadraoMinutos   Int      @default(480)  // 8h = 480min
  horarioEntrada         String   @default("08:00") // formato HH:MM
  horarioSaida           String   @default("17:00")
  intervaloMinimoMinutos Int      @default(60)   // 1h mínimo CLT
  toleranciaMinutos      Int      @default(10)   // tolerância de registro
  notifAntecedenciaMin   Int      @default(15)   // notificar X min antes
  notifHoraExtraMin      Int      @default(30)   // perguntar hs extras a cada X min
  diasTrabalho           Json     @default("[1,2,3,4,5]") // 0=Dom, 6=Sab
  limiteHoraExtraDia     Int      @default(120)  // 2h = 120min CLT
  limiteHoraSemana       Int      @default(2640) // 44h = 2640min CLT
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("configuracoes")
}

// ==========================================
// MODELO: Registro de Ponto
// ==========================================
model RegistroPonto {
  id                String          @id @default(uuid())
  userId            String
  data              DateTime        @db.Date
  entrada           DateTime?
  inicioIntervalo   DateTime?
  fimIntervalo      DateTime?
  saida             DateTime?
  horasTrabalhadasMin Int?          // calculado em minutos
  horasExtrasMin    Int?            // calculado em minutos
  intervaloDuracaoMin Int?          // duração real do intervalo
  status            StatusPonto     @default(NORMAL)
  observacao        String?
  intervaloAdiado   Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  justificativa  Justificativa?  @relation(fields: [justificativaId], references: [id])
  justificativaId String?
  logs           Log[]

  @@unique([userId, data])
  @@index([userId, data])
  @@map("registros_ponto")
}

// ==========================================
// MODELO: Justificativa de Ausência (Art. 473 CLT)
// ==========================================
model Justificativa {
  id            String             @id @default(uuid())
  userId        String
  tipo          TipoJustificativa
  motivo        String
  anexoUrl      String?            // Caminho do PDF/Imagem
  dataInicio    DateTime           @db.Date
  dataFim       DateTime           @db.Date
  status        StatusJustificativa @default(PENDENTE)
  acaoRH        AcaoRH?            // Decisão sobre o tempo
  observacaoRH  String?
  confirmadoUser Boolean           @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  registros     RegistroPonto[]

  @@map("justificativas")
}

// ==========================================
// MODELO: Banco de Horas
// ==========================================
model BancoHoras {
  id              String   @id @default(uuid())
  userId          String   @unique
  saldoMinutos    Int      @default(0)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("banco_horas")
}

// ==========================================
// MODELO: Log de eventos
// ==========================================
model Log {
  id              String      @id @default(uuid())
  userId          String
  registroId      String?
  tipoEvento      TipoEvento
  origem          OrigemEvento @default(MANUAL)
  timestamp       DateTime    @default(now())
  detalhes        Json?
  ip              String?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  registro RegistroPonto? @relation(fields: [registroId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@map("logs")
}

// ==========================================
// ENUMS
// ==========================================
enum UserRole {
  COLABORADOR
  ADMIN_RH
}

enum StatusPonto {
  NORMAL
  FALTA
  ATESTADO
  FERIADO
  FOLGA
  MEIO_PERIODO
}

enum TipoJustificativa {
  ATESTADO_MEDICO
  ATESTADO_ACOMPANHANTE
  OBITO
  CASAMENTO
  NASCIMENTO_FILHO
  DOACAO_SANGUE
  ALISTAMENTO_MILITAR
  VESTIBULAR
  JUSTICA
  CONVOCACAO_ELEITORAL
  OUTROS
}

enum StatusJustificativa {
  PENDENTE
  EM_REVISAO
  APROVADO
  REJEITADO
}

enum AcaoRH {
  ABONAR      // Paga o dia, não desconta banco
  COMPENSAR   // Adiciona débito ao Banco de Horas
  DESCONTAR   // Desconto direto em folha (falta)
}

enum TipoEvento {
  ENTRADA
  INICIO_INTERVALO
  FIM_INTERVALO
  SAIDA
  HORA_EXTRA_INICIO
  HORA_EXTRA_FIM
  NOTIFICACAO_ENVIADA
  AUTO_REGISTRO
  AJUSTE_MANUAL
  LOGIN
  LOGOUT
  JUSTIFICATIVA_UPLOAD
  JUSTIFICATIVA_VALIDADA
}

enum OrigemEvento {
  MANUAL
  AUTOMATICO
  SISTEMA
}
